# DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require

# Must match frontend `JWT_SECRET` (middleware verifies cookies). Use a long random string in production.
# JWT_SECRET=

# Optional: create first admin when no admin exists (e.g. local dev).
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=

# Pool tuning (Neon / serverless closes idle connections — recycle early).
# DB_IDLE_TIMEOUT_SECS=300
# DB_MAX_LIFETIME_SECS=1800
# DB_MAX_CONNECTIONS=5
# DB_ACQUIRE_TIMEOUT_SECS=30
